# =========================================================================
# ActionOS Environment Configuration Template
# Copy this file to '.env' and fill in your details.
# =========================================================================

# Active AI Provider: 'gemini' | 'deepseek' | 'claude' | 'openai' | 'mock'
# If set to 'mock' (default), it parses prompts offline without external API calls.
AI_PROVIDER=mock

# Active AI Model Name (Optional, defaults to reasonable models if omitted)
# gemini: gemini-1.5-flash | gemini-2.5-flash
# deepseek: deepseek-chat
# claude: claude-3-5-sonnet-latest
# openai: gpt-4o-mini
AI_MODEL=

# --- Google Gemini ---
GEMINI_API_KEY=

# --- Deepseek ---
DEEPSEEK_API_KEY=
# Optional: DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=
# Optional: OPENAI_BASE_URL=https://api.openai.com/v1
