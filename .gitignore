/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist/
/.vite/

# generated search artifacts
public/pagefind/
public/_pagefind/
public/search-index.json
.cache/
