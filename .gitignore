.env
.env.local
.env.development
.env.production
.profile-models.json

# 但保留示例文件
!.env.example

# local database files containing private task and habit data
action-db.json


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / tools
.specstory/

# wrangler
.wrangler/

# local secrets
.dev.vars

